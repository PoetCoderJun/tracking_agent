
# >>> conda initialize >>>
# !! Contents within this block are managed by 'conda init' !!
__conda_setup="$('/opt/homebrew/Caskroom/miniconda/base/bin/conda' 'shell.zsh' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "/opt/homebrew/Caskroom/miniconda/base/etc/profile.d/conda.sh" ]; then
        . "/opt/homebrew/Caskroom/miniconda/base/etc/profile.d/conda.sh"
    else
        export PATH="/opt/homebrew/Caskroom/miniconda/base/bin:$PATH"
    fi
fi

unset __conda_setup
# <<< conda initialize <<<

# OMX OpenClaw integration
if [ -z "${HOOKS_TOKEN:-}" ] && [ -f "$HOME/.openclaw/openclaw.json" ] && command -v jq >/dev/null 2>&1; then
  export HOOKS_TOKEN="$(jq -r '.hooks.token // .gateway.auth.token // empty' "$HOME/.openclaw/openclaw.json" 2>/dev/null)"
fi
export OMX_OPENCLAW="1"

export ENABLE_LSP_TOOLS=1

# Added by Hugging Face CLI installer
export PATH="/Users/cmhk/.local/bin:$PATH"

# OpenClaw Completion
if ! whence compdef >/dev/null; then
    autoload -Uz compinit
    compinit
fi
source "/Users/cmhk/.openclaw/completions/openclaw.zsh"

# OpenClaw proxy
export NODE_USE_ENV_PROXY="1"
export HTTP_PROXY="http://127.0.0.1:10090"
export HTTPS_PROXY="http://127.0.0.1:10090"
export ALL_PROXY="http://127.0.0.1:10090"
export NO_PROXY="127.0.0.1,localhost"
export no_proxy="127.0.0.1,localhost"

# Terminal-only smart paste: Ctrl+V saves clipboard images to a temp file and
# inserts the path. Command+V remains the terminal's native paste behavior.
if [[ -o interactive ]] && command -v zle >/dev/null 2>&1; then
  smart_clipboard_payload() {
    local clip_dir="${TMPDIR:-/tmp}/codex-clipboard-images"
    local stamp suffix file

    mkdir -p -- "$clip_dir" || return 1
    stamp="$(date +%Y%m%d-%H%M%S)"
    suffix="$(printf '%04X' $((RANDOM % 65536)))"
    file="$clip_dir/clip-${stamp}-${suffix}.png"

    if command -v pngpaste >/dev/null 2>&1 && pngpaste "$file" >/dev/null 2>&1; then
      printf '%s' "$file"
      return 0
    fi

    rm -f -- "$file"
    pbpaste 2>/dev/null
  }

  smart_clipboard_paste() {
    local payload
    payload="$(smart_clipboard_payload)" || return 0
    LBUFFER+="$payload"
  }

  zle -N smart_clipboard_paste
  bindkey '^V' smart_clipboard_paste
fi
