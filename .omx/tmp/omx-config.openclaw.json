{
  "notifications": {
    "enabled": true,
    "verbosity": "session",
    "events": {
      "session-start": {
        "enabled": true
      },
      "session-idle": {
        "enabled": true
      },
      "ask-user-question": {
        "enabled": true
      },
      "session-stop": {
        "enabled": true
      },
      "session-end": {
        "enabled": true
      }
    },
    "openclaw": {
      "enabled": true,
      "gateways": {
        "local": {
          "type": "http",
          "url": "http://127.0.0.1:18789/hooks/agent",
          "headers": {
            "Authorization": "Bearer ${HOOKS_TOKEN}"
          }
        }
      },
      "hooks": {
        "session-start": {
          "enabled": true,
          "gateway": "local",
          "instruction": "[session-start] project={{projectName}} session={{sessionId}} tmux={{tmuxSession}}"
        },
        "session-idle": {
          "enabled": true,
          "gateway": "local",
          "instruction": "[session-idle] project={{projectName}} session={{sessionId}} tmux={{tmuxSession}}"
        },
        "ask-user-question": {
          "enabled": true,
          "gateway": "local",
          "instruction": "[ask-user-question] session={{sessionId}} tmux={{tmuxSession}} question={{question}}"
        },
        "stop": {
          "enabled": true,
          "gateway": "local",
          "instruction": "[session-stop] project={{projectName}} session={{sessionId}} tmux={{tmuxSession}}"
        },
        "session-end": {
          "enabled": true,
          "gateway": "local",
          "instruction": "[session-end] project={{projectName}} session={{sessionId}} tmux={{tmuxSession}} reason={{reason}}"
        }
      }
    }
  }
}
